<section class="text-size-2">
  <h2>Finding elements by CSS selector</h2>

  <div class="mt-600r fragment">
    <p>
      Use <code>page.locator()</code> to find elements with
      <strong>CSS selectors</strong>
    </p>
    <pre style="width: fit-content">
      <code class="ts" data-trim>
        page.locator('button', {hasText: 'Search'}) 
      </code>
    </pre>
  </div>

  <div class="ms-200r mt-200r flex-row flex-row--center">
    <div class="sticky fragment">
      <u>Use with caution:</u>
      <div class="sticky__content">
        The DOM can often change, <br />
        making these locators more brittle
      </div>
    </div>
  </div>
</section>

<section class="text-size-5">
  <h3>CSS selectors for the automation engineer</h3>

  <div class="mt-200r fragment">
    <div class="flex-row" style="gap: 1em">
      <pre style="width: unset">
        <code class="html" data-trim data-line-numbers="11-13" style="padding-right:2em;">
          &lt;html>
            &lt;body>
              &lt;main class="container">
                &lt;h1>
                  CSS selectors
                &lt;/h1>
                &lt;article>  
                  &lt;h2>
                    Hello
                  &lt;/h2>
                  &lt;p class="box info" id="message">
                    Select me!
                  &lt;/p>
                &lt;/article>
              &lt;/main>
            &lt;/body>
          &lt;/html>
        </code>
      </pre>
      <div class="fragment" style="flex-basis: 55%">
        <p>How can we select the <code>p</code> tag ?</p>
        <table
          class="mt-50r no-border vspace-half"
          style="width: 100%; font-size: 0.9em"
        >
          <tr class="fragment">
            <td width="50%">‣ With an <b>Element selector</b></td>
            <td>
              <code>p</code>
            </td>
          </tr>
          <tr class="fragment">
            <td>‣ With an <b>Class selector</b></td>
            <td>
              <code>.info</code>
            </td>
          </tr>
          <tr class="fragment">
            <td>‣ With an <b>Id selector</b></td>
            <td>
              <code>#message</code>
            </td>
          </tr>
          <tr class="fragment">
            <td>‣ Or by combining selectors</td>
            <td>
              <code>.container&nbsp;p.box.info</code>
            </td>
          </tr>
        </table>
        <p class="mt-200r fragment">Or with advanced combinators</p>
        <table
          class="mt-50r no-border vspace-half"
          style="width: 100%; font-size: 0.9em"
        >
          <tr class="fragment">
            <td width="50%">‣ Immediate child</td>
            <td>
              <code>article&nbsp;>&nbsp;p</code>
            </td>
          </tr>
          <tr class="fragment">
            <td>‣ General sibling</td>
            <td>
              <code>h2&nbsp;~&nbsp;p</code>
            </td>
          </tr>
          <tr class="fragment">
            <td>‣ Adjacent sibling</td>
            <td>
              <code>h2&nbsp;+&nbsp;p</code>
            </td>
          </tr>
        </table>
      </div>
    </div>
  </div>

  <div class="mt-200r fragment">
    <p>Verify your selectors</p>
    <ul>
      <li>
        With <strong>css-and-xpath-checker</strong>:
        <a
          href="https://chromewebstore.google.com/detail/css-and-xpath-checker/aoinfihhckpkkcpholfhmkeplbhddipe"
        >
          https://chromewebstore.google.com/detail/css-and-xpath-checker/...
        </a>
      </li>
      <li>Or with <code>$$('')</code> in the browser's console</li>
    </ul>
    <p class="mt-200r fragment">
      And learn more with
      <a href="https://flukeout.github.io/" target="_blank">CSS Diner</a>!
    </p>
  </div>
</section>
